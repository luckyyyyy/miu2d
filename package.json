{
  "name": "miu2d",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "turbo run dev gen:trpc:watch --parallel --filter=@miu2d/web --filter=@miu2d/server --filter=@miu2d/types",
    "dev:web": "turbo run dev --filter=@miu2d/web",
    "dev:server": "turbo run dev gen:trpc:watch --parallel --filter=@miu2d/server --filter=@miu2d/types",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @miu2d/types build && pnpm --filter @miu2d/server db:generate && pnpm --filter @miu2d/server gen:trpc && pnpm --filter @miu2d/engine build && pnpm --filter @miu2d/web build",
    "build:wasm": "bash scripts/build-wasm.sh",
    "lint": "biome lint packages/",
    "format": "biome format --write packages/",
    "check": "biome check --write packages/",
    "tsc": "pnpm -r tsc",
    "preview": "pnpm --filter @miu2d/web preview",
    "db:up": "docker-compose up -d db minio",
    "db:down": "docker-compose down",
    "db:migrate": "pnpm --filter @miu2d/server db:migrate",
    "db:seed": "pnpm --filter @miu2d/server db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "turbo": "^2.8.17",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "vite": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "sharp",
      "bcrypt"
    ]
  }
}
