{
  "name": "@miu2d/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/@generated/app-router.ts"
  },
  "scripts": {
    "gen:trpc": "tsx scripts/generate-trpc-types.ts",
    "gen:trpc:watch": "tsx scripts/generate-trpc-types.ts --watch",
    "dev": "pnpm db:generate && tsx watch --tsconfig tsconfig.dev.json src/main.ts",
    "prebuild": "pnpm -C ../types build && prisma generate",
    "build": "pnpm gen:trpc && rolldown -c rolldown.config.mjs",
    "start": "node dist/main.js",
    "tsc": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx --tsconfig tsconfig.dev.json src/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.982.0",
    "@aws-sdk/s3-request-presigner": "^3.982.0",
    "@smithy/node-http-handler": "^4.4.9",
    "@hono/node-server": "^1.19.9",
    "@hono/trpc-server": "^0.4.2",
    "@miu2d/shared": "workspace:*",
    "@miu2d/types": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@react-email/components": "^1.0.7",
    "@trpc/server": "^11.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.9",
    "nodemailer": "^8.0.1",
    "pg": "^8.14.0",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-email": "^5.2.8",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "tslib": "^2.8.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.0.9",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.11.14",
    "@types/react": "^19.2.10",
    "chokidar": "^5.0.0",
    "rolldown": "^1.0.0-rc.9",
    "ts-morph": "^27.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
