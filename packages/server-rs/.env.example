# ======================================
# Rust Server 环境变量 (本地开发)
# ======================================

# 数据库连接 URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/miu2d_db

# 运行环境 (development / production)
# NODE_ENV=development

# 服务端口（默认 4000）
# PORT=4000

# MinIO (S3 兼容文件存储)
# 优先读取 MINIO_ACCESS_KEY/MINIO_SECRET_KEY，回退到 MINIO_ROOT_USER/MINIO_ROOT_PASSWORD
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_PUBLIC_ENDPOINT=/s3
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=minio123
# MINIO_BUCKET=miu2d

# SMTP 邮件发送配置
# 不配置则跳过邮件发送（日志中会有警告）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=Miu2D Engine <noreply@example.com>

# 前端 URL（用于邮件中的链接）
APP_URL=http://localhost:5173

# Session
# SESSION_COOKIE_SECURE=false

# 开发模式自动登录（仅 development 环境生效，默认 true）
# DEV_AUTO_LOGIN=true

# Rust 日志级别
# RUST_LOG=miu2d_server=debug,tower_http=debug
